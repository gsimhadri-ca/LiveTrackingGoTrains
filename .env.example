# Copy this file to .env and fill in your values
# .env is gitignored — never commit your real key

METROLINX_API_KEY=30027709

# ── Anthropic API (LangChain agent — Phase 2) ─────────────────────
# Get your key at platform.claude.com → API Keys
# Create a personal key separate from the Temple project key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM model to use (claude-haiku-4-5-20251001 is cheapest)
AGENT_MODEL=claude-haiku-4-5-20251001

# ── Web server (Phase 2) ──────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8000

# ── LangSmith tracing (optional) ─────────────────────────────────
# Sign up at smith.langchain.com to get a free API key
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key_here
# LANGCHAIN_PROJECT=livetracking-gotrains

# ── Polling behaviour ─────────────────────────────────────────────
# Polling interval in seconds (default: 30)
POLL_INTERVAL_SECONDS=30

# Delay threshold in seconds to trigger an alert (default: 300 = 5 minutes)
DELAY_THRESHOLD_SECONDS=300

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Agent toggle (Phase 2) ────────────────────────────────────────────────────
# Set false to disable Claude API calls (no token usage)
AGENT_ENABLED=true

# ── Redis + Kafka (Phase 3) ───────────────────────────────────────────────────
# Run both with: docker compose up -d
REDIS_URL=redis://localhost:6379/0
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Email alerts (Phase 3 — leave SMTP_HOST blank to log-only in dev) ─────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@gotransit.local
